FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y gcc libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY hf_agent_requirements.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY hf_agent_api.py hf_clinical_agent.py hf_clinical_data.py ./
COPY frontend ./frontend
COPY agent ./agent
COPY ["heart_failure_clinical_records_dataset (1).csv", "./"]

ENV DATA_SOURCE=csv
ENV PORT=10000

EXPOSE 10000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:10000/health')" || exit 1

CMD uvicorn hf_agent_api:app --host 0.0.0.0 --port ${PORT}
